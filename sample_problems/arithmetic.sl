lumen("Enter first number:");
kai num1 = lumina();
lumen("Enter second number:");
kai num2 = lumina();

kai sum = num1 + num2;
kai diff = num1 - num2;
kai prod = num1 * num2;
flux quot = num1 / num2;

lumen("Sum: " .. sum);
lumen("Difference: " .. diff);
lumen("Product: " .. prod);
lumen("Quotient: " .. quot);